# ============================================
# DOCKER & DEPLOYMENT CONFIGURATION
# ============================================

# Docker Hub Configuration
DOCKER_USERNAME=your-docker-username
TAG=latest

# ============================================
# SERVICE CONFIGURATION
# ============================================

CONFIG_PATH=config
CONFIG_FILE=config

# Service Hostnames
AUTH_SERVICE_HOST=proftwist-auth-service
CATEGORY_SERVICE_HOST=proftwist-category-service
CHAT_SERVICE_HOST=proftwist-chat-service
FRIEND_SERVICE_HOST=proftwist-friend-service
MODERATION_SERVICE_HOST=proftwist-moderation-service
ROADMAP_SERVICE_HOST=proftwist-roadmap-service
ROADMAPINFO_SERVICE_HOST=proftwist-roadmapinfo-service
MATERIAL_HOST=proftwist-material-service

# ============================================
# DATABASE CONFIGURATION
# ============================================

# PostgreSQL
POSTGRES_HOST=proftwist-postgres
POSTGRES_PORT=5432
POSTGRES_DB=proftwist_postgres_db
POSTGRES_USER=user
POSTGRES_PASSWORD=password

# MongoDB
MONGO_HOST=proftwist-mongo
MONGO_PORT=27017
MONGO_DB=proftwist_mongo_db
MONGO_USERNAME=user
MONGO_PASSWORD=password

# Redis
REDIS_HOST=proftwist-redis
REDIS_PORT=6379
REDIS_PASSWORD=password
REDIS_DB=0

# ============================================
# ADMIN INTERFACES
# ============================================

# PGAdmin
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=password

# Mongo Express
MONGO_EXPRESS_USERNAME=user
MONGO_EXPRESS_PASSWORD=password

# Redis Commander
REDIS_COMMANDER_USER=user
REDIS_COMMANDER_PASSWORD=password

# ============================================
# SECURITY & AUTHENTICATION
# ============================================

JWT_SECRET=your-jwt-secret

# VK Integration
VK_INTEGRATION_ID=your-vk-integration-id
VK_REDIRECT_URL=https://your-domain.com/auth/vk/callback
VK_SECRET_KEY=your-vk-secret-key

# ============================================
# STORAGE (MinIO/S3)
# ============================================

MINIO_ROOT_USER=user
MINIO_ROOT_PASSWORD=password
MINIO_ENDPOINT=proftwist-minio:9000
MINIO_FILES_ENDPOINT=

# ============================================
# EXTERNAL SERVICES
# ============================================

# AI Services
AI_PROVIDER=openai
OLLAMA_BASE_URL=http://host.docker.internal:11434/v1
OLLAMA_API_KEY=
OPENAI_MODEL=openrouter/auto
OPENAI_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=your-openai-api-key

# Kafka
KAFKA_BROKER=proftwist-kafka:9092

# Bot Configuration
BOT_USER_ID="00000000-0000-0000-0000-000000000000"
BOT_TRIGGER_PHRASE="your-bot-trigger-phrase"

# Grafana
GRAFANA_USER=user
GRAFANA_PASSWORD=password
